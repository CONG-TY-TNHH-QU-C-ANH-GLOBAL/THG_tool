# THG AutoFlow — LOCAL DEVELOPMENT data platform env example.
#
# ⚠️  LOCAL DEVELOPMENT ONLY. Copy to deploy/dev/.env (git-ignored) and adjust.
#     NEVER put real production secrets here. These values are safe local
#     defaults that match deploy/dev/docker-compose.yml.
#
# IMPORTANT (PR9 scope): NONE of the Postgres/Redis variables below are wired
# into the application runtime yet. SQLite remains the default and only runtime
# database. DB_DRIVER is documentation only — it is NOT read by app startup.
# See docs/architecture/ADR-PR9-DATA-PLATFORM.md.

# === Active runtime DB (unchanged) ===
# SQLite is the current default. The app reads DB_PATH today (see .env.example
# at repo root / cmd/worker/main.go). SQLITE_PATH is documented here for the
# future driver-select layer; it mirrors the existing DB_PATH default.
DB_DRIVER=sqlite
SQLITE_PATH=data/scraper.db

# === PostgreSQL (FUTURE source of truth — local dev container only) ===
# Matches deploy/dev/docker-compose.yml defaults. sslmode=disable is for LOCAL
# dev only; production must use sslmode=require with real, uncommitted secrets.
POSTGRES_DB=thg_autoflow
POSTGRES_USER=thg
POSTGRES_PASSWORD=thg_local_dev
POSTGRES_DSN=postgres://thg:thg_local_dev@localhost:5432/thg_autoflow?sslmode=disable

# === Redis (EPHEMERAL only — never a durable source of truth) ===
# Redis is for ephemeral acceleration (presence/rate-limit/cache). It is NOT a
# durable store for task/queue/ledger/proof/policy data. See the ADR.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
