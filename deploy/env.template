# /etc/thg-scraper/env
# Owner: root   Group: thg-scraper   Mode: 640 (root writes, service reads, others NOTHING)
# Set with: sudo nano /etc/thg-scraper/env

# ── Required secrets ──────────────────────────────────────────────────────
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Generate both with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# ── Admin bootstrap (remove after first login!) ───────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# ── CORS (your actual domain) ─────────────────────────────────────────────
ALLOWED_ORIGINS=https://sale.thgfulfill.com

# ── AI models ─────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMMENT_MODEL=gpt-4.1

# ── App config ────────────────────────────────────────────────────────────
WEB_PORT=8080
APP_BASE_URL=https://sale.thgfulfill.com
DB_PATH=/opt/thg-scraper/data/scraper.db
PROFILE_DIR=/opt/thg-scraper/data/profiles
BACKUP_ENABLED=true
MAX_WORKERS=1
SCAN_INTERVAL_MIN=30
SCROLL_TIMEOUT_SEC=60

# Chrome path (installed by setup.sh)
CHROME_PATH=/usr/bin/chromium-browser

# Email invites (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=THG AutoFlow
SMTP_TLS=false
SMTP_STARTTLS=true
SMTP_SKIP_VERIFY=false

# Chrome Web Store extension install
# Official THG Chrome Extension. The API can derive the store URL from this ID.
CHROME_EXTENSION_ID=nhalaldgpkoopgddccelckhaiegdbmfb
CHROME_EXTENSION_STORE_URL=

# Temporary beta fallback while a new official version is under Google review.
CHROME_EXTENSION_BETA_ENABLED=false
CHROME_EXTENSION_BETA_URL=
CHROME_EXTENSION_BETA_PACKAGE_URL=
CHROME_EXTENSION_BETA_PACKAGE_PATH=/opt/thg-scraper/releases/thg-chrome-extension.zip

# ── Agent Brain sidecar (LLM Planner) ─────────────────────────────────────
# Python sidecar that enriches prompts with MarketSignalGate via LLM.
# Leave empty to disable (Go falls back to deterministic logic).
AGENT_BRAIN_URL=http://127.0.0.1:8091
AGENT_BRAIN_TIMEOUT_MS=3000
