{
  "manifest_version": 3,
  "name": "THG Chrome Extension",
  "description": "Connect a signed-in Facebook tab to a THG workspace for dashboard streaming and automation.",
  "version": "0.5.2",
  "action": {
    "default_title": "THG Chrome",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "cookies",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://sale.thgfulfill.com/*",
    "https://*.thgfulfill.com/*",
    "https://facebook.com/*",
    "https://*.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://facebook.com/*",
        "https://*.facebook.com/*"
      ],
      "js": [
        "content/shared.js",
        "content/meta.js",
        "content/commands.js",
        "content/crawl.js",
        "content/proof.js",
        "content/outbound.js",
        "content/bridge.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
