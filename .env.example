# THG Agentic Scraper - Environment Configuration
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit .env to git — it contains secrets!

# === Required ===
OPENAI_API_KEY=sk-your-key-here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# === AI Models ===
# Two-model split: classifier runs on every crawled post (high volume,
# strict json_schema output) → cheap+fast model. Comment generation runs
# once per outbound message and is user-facing → strong model.
#
# Production note: CI/CD does NOT push env to the VPS. To update models in
# production, SSH in and edit /etc/thg-scraper/env, then run:
#   sudo systemctl restart thg-scraper thg-worker
#
# Classifier (UniversalClassify, price extraction). Recommended:
# gpt-4o-mini / gpt-5.4-mini / gpt-5-nano.
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
# Legacy alias — config.go falls back to OPENAI_MODEL if the new
# OPENAI_CLASSIFIER_MODEL isn't set. Keeps existing VPS env files working
# until they get migrated. Drop after migration.
OPENAI_MODEL=gpt-4o-mini
# Comment + inbox + post generation + agent reasoning. Recommended:
# gpt-4.1 / gpt-5.4.
OPENAI_COMMENT_MODEL=gpt-4.1
#
# --- Alternative chat provider (OpenAI-compatible) ------------------------
# Route the CHAT callers (classifier + comment generation) at a cheaper
# OpenAI-compatible provider such as Together AI. Leave LLM_BASE_URL blank to
# keep the built-in OpenAI endpoint. When set, LLM_API_KEY is used for those
# chat calls (falls back to OPENAI_API_KEY if blank), and the model names above
# must be the provider's model IDs. Embeddings + price-vision still use
# OPENAI_API_KEY, so keep that key set.
# Example (Together AI, verified serverless + json_schema):
#   LLM_BASE_URL=https://api.together.xyz/v1
#   LLM_API_KEY=tgp_...
#   OPENAI_CLASSIFIER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   OPENAI_COMMENT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
LLM_BASE_URL=
LLM_API_KEY=
# Optional schema-first planner sidecar. Docker Compose defaults to http://agent-brain:8091.
AGENT_BRAIN_URL=
AGENT_BRAIN_TIMEOUT_MS=1500

# === Security ===
# JWT signing secret — REQUIRED in production (min 32 random bytes)
# Generate: openssl rand -hex 32
JWT_SECRET=

# AES-256-GCM key for encrypting Facebook session cookies in DB — REQUIRED in production
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Comma-separated allowed CORS origins (empty = localhost only)
ALLOWED_ORIGINS=http://localhost:8080

# Legacy API key (deprecated — use JWT_SECRET above)
API_SECRET=

# === Admin Bootstrap ===
# Set these ONCE to create the first admin user on a cold start.
# Remove after first login to prevent accidental reuse.
# Password must be: 10+ chars, 1 uppercase, 1 digit, 1 special char
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# === Chrome ===
# Leave empty to auto-detect Chrome binary
CHROME_PATH=
# Absolute path recommended in production to avoid working-directory issues
PROFILE_DIR=data/profiles
# Force headless mode (auto-detected on Linux VPS without display — usually leave empty)
HEADLESS=
# Public hostname/IP shown in SSH tunnel instructions when adding FB accounts on VPS
# Example: 103.216.117.194  or  sale.thgfulfill.com
SERVER_HOST=
# SSH port for tunnel instructions (default 22)
SSH_PORT=22

# === Web UI ===
WEB_PORT=8080
# Public dashboard URL used inside staff invite emails.
# Production example: https://sale.thgfulfill.com
APP_BASE_URL=http://localhost:3000

# === Email Invites (SMTP) ===
# Generic SMTP works with Gmail Workspace app password, Brevo, SES SMTP, Resend SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=THG AutoFlow
# Use SMTP_TLS=true for implicit TLS on port 465. For port 587 keep TLS=false and STARTTLS=true.
SMTP_TLS=false
SMTP_STARTTLS=true
SMTP_SKIP_VERIFY=false

# === Database ===
DB_PATH=data/scraper.db
# Auto-backup SQLite daily (true/false)
BACKUP_ENABLED=true

# === Scraper Settings ===
MAX_WORKERS=1
SCROLL_TIMEOUT_SEC=60
SCAN_INTERVAL_MIN=30

# === Proxy (optional, comma-separated) ===
# Format: protocol://user:pass@host:port
PROXY_LIST=

# === Chrome Extension Beta ===
# Enable to serve the latest CI-built Chrome Extension zip to beta users via /api/system/extension-beta-package
# Beta users will see updates automatically because CI injects the GitHub run_number into the manifest version (e.g., 0.3.0.42).
# They just need to wait for Chrome to auto-update, or click "Update" in chrome://extensions.
CHROME_EXTENSION_BETA_ENABLED=false
